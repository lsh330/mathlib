{
  "version": "0.2.1",
  "tasks": [
    {
      "appliesTo": "*",
      "type": "default",
      "contextType": "build",
      "taskLabel": "Build Cython (MSVC, inplace)",
      "command": "${workspaceRoot}\\.vs\\build.cmd",
      "args": [],
      "workingDirectory": "${workspaceRoot}",
      "presentation": { "echo": true, "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "appliesTo": "*",
      "type": "default",
      "contextType": "clean",
      "taskLabel": "Clean Build Artifacts",
      "command": "${workspaceRoot}\\.vs\\clean.cmd",
      "args": [],
      "workingDirectory": "${workspaceRoot}"
    },
    {
      "appliesTo": "*",
      "type": "default",
      "contextType": "custom",
      "taskLabel": "Install Build Dependencies",
      "command": "${workspaceRoot}\\.vs\\run.cmd",
      "args": [ "-m", "pip", "install", "Cython>=3.1", "wheel", "numpy", "setuptools" ],
      "workingDirectory": "${workspaceRoot}"
    },
    {
      "appliesTo": "*",
      "type": "default",
      "contextType": "custom",
      "taskLabel": "Run pytest (all tests)",
      "command": "${workspaceRoot}\\.vs\\run.cmd",
      "args": [ "-m", "pytest", "tests", "-v" ],
      "workingDirectory": "${workspaceRoot}"
    },
    {
      "appliesTo": "tests/*.py",
      "type": "default",
      "contextType": "custom",
      "taskLabel": "Run pytest (current file)",
      "command": "${workspaceRoot}\\.vs\\run.cmd",
      "args": [ "-m", "pytest", "${file}", "-v" ],
      "workingDirectory": "${workspaceRoot}"
    },
    {
      "appliesTo": "bench/*.py",
      "type": "default",
      "contextType": "custom",
      "taskLabel": "Run bench (current file)",
      "command": "${workspaceRoot}\\.vs\\run.cmd",
      "args": [ "${file}" ],
      "workingDirectory": "${workspaceRoot}"
    },
    {
      "appliesTo": "*",
      "type": "default",
      "contextType": "custom",
      "taskLabel": "Install Editable (pip install -e .)",
      "command": "${workspaceRoot}\\.vs\\run.cmd",
      "args": [
        "-m", "pip", "install", "-e", ".",
        "--no-build-isolation",
        "--config-settings=--build-option=--compiler=msvc"
      ],
      "workingDirectory": "${workspaceRoot}"
    }
  ]
}
